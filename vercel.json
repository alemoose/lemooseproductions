{
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/uploads/(.*\\.(avif|jpg|png|webp))",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/work/portraits", "destination": "/work/portraits.html" },
    { "source": "/work/portraits/", "destination": "/work/portraits.html" },
    { "source": "/work/automotive", "destination": "/work/automotive.html" },
    { "source": "/work/automotive/", "destination": "/work/automotive.html" },
    { "source": "/work/athletes", "destination": "/work/athletes.html" },
    { "source": "/work/athletes/", "destination": "/work/athletes.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
